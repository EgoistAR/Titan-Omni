local function runEliteScanner()

    -- SADECE GERÇEK WHITELIST
    local WhitelistedIDs = {
        9446736086,
        4562707344,
        3446958708
    }

    -- WHITELIST KONTROLÜ
    for _, id in ipairs(WhitelistedIDs) do
        if LP.UserId == id then
            return true
        end
    end

    -- GAMEPASS SATIN ALMA KONTROLÜ
    local success, ownsPass = pcall(function()
        return MarketplaceService:UserOwnsGamePassAsync(
            LP.UserId,
            PREMIUM_ID
        )
    end)

    -- HATA VARSA FALSE
    if not success then
        warn("Premium check failed.")
        return false
    end

    -- SADECE SATIN ALDIYSA TRUE
    return ownsPass == true
end


        local success, err = pcall(function()
            -- Oyunun kullanabileceği olası açma fonksiyonlarını (method) deniyoruz
            if type(PanelController.Open) == "function" then
                PanelController:Open(panelName)
            elseif type(PanelController.OpenPanel) == "function" then
                PanelController:OpenPanel(panelName)
            elseif type(PanelController.Toggle) == "function" then
                PanelController:Toggle(panelName, true)
            else
                warn("⚠️ [PANEL] Açma fonksiyonu bulunamadı!")
            end
        end)

        if success then
            sendNotify("🖥️ Panel", panelName .. " opened! ✅")
        else
            sendNotify("❌ Error", "Failed to open: " .. tostring(err))
        end
    end
})

XenoTab:AddButton({
    Name = "🔴 Close Panel",
    Callback = function()
        local panelName = XenoSettings.TargetPanel
        if not panelName or panelName == "" then return end

        pcall(function()
            if type(PanelController.Close) == "function" then
                PanelController:Close(panelName)
            elseif type(PanelController.ClosePanel) == "function" then
                PanelController:ClosePanel(panelName)
            elseif type(PanelController.Toggle) == "function" then
                PanelController:Toggle(panelName, false)
            end
        end)
        sendNotify("🖥️ Panel", panelName .. " closed! ⛔")
    end
})


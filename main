-- ==========================================
-- ⚙️ GELİŞMİŞ AYARLAR & KARAKTER (TITAN OMNI MAX)
-- ==========================================
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local VirtualUser = game:GetService("VirtualUser")
local Lighting = game:GetService("Lighting")

local SettingsTab = Window:MakeTab({ Name = T("Settings") or "Ayarlar/Oyuncu", Icon = "rbxassetid://7072721682" })

-- // DEĞİŞKENLER (Toggles)
local _G = _G or {}
_G.LoopSpeed = false
_G.TargetSpeed = 16
_G.InfJump = false
_G.Noclip = false
_G.FullBright = false

-- ==========================================
-- 🌐 SİSTEM VE DİL AYARLARI
-- ==========================================
SettingsTab:AddSection(T("SysSettings") or "Sistem ve Dil")

SettingsTab:AddDropdown({
    Name = "Language / Dil / Idioma",
    Default = currentLang,
    Options = {"Turkish","English"},
    Callback = function(Value)
        currentLang = Value
        pcall(function() if writefile then writefile("TitanOmni_Language.txt", Value) end end)
        sendNotify("Titan Omni", T("LangSet") or "Dil başarıyla değiştirildi!", "rbxassetid://135403840994127")
    end
})

SettingsTab:AddToggle({
    Name = "Anti-AFK (Kick Koruması)",
    Default = false,
    Callback = function(Value)
        if Value then
            -- Oyunun seni 20 dakika hareketsizlikten atmasını engeller
            LP.Idled:Connect(function()
                VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                task.wait(1)
                VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
            end)
            sendNotify("Titan Omni", "Anti-AFK Aktif!", "rbxassetid://135403840994127")
        end
    end
})

-- ==========================================
-- 🏃 KARAKTER VE FİZİK MANİPÜLASYONU
-- ==========================================
SettingsTab:AddSection(T("CharSet") or "Karakter Fizikleri")

SettingsTab:AddSlider({
    Name = "WalkSpeed (Hız)", Min = 16, Max = 300, Default = 16,
    Callback = function(v) 
        _G.TargetSpeed = v
        if LP.Character and LP.Character:FindFirstChild("Humanoid") then 
            LP.Character.Humanoid.WalkSpeed = v 
        end 
    end
})

SettingsTab:AddToggle({
    Name = "Loop WalkSpeed (Anti-Hız Sıfırlama)",
    Default = false,
    Callback = function(Value)
        _G.LoopSpeed = Value
    end
})

SettingsTab:AddSlider({
    Name = "JumpPower (Zıplama Gücü)", Min = 50, Max = 500, Default = 50,
    Callback = function(v) 
        if LP.Character and LP.Character:FindFirstChild("Humanoid") then 
            LP.Character.Humanoid.UseJumpPower = true
            LP.Character.Humanoid.JumpPower = v 
        end 
    end
})

SettingsTab:AddToggle({
    Name = "Infinite Jump (Sınırsız Zıplama)",
    Default = false,
    Callback = function(Value)
        _G.InfJump = Value
    end
})

SettingsTab:AddToggle({
    Name = "Noclip (Duvarlardan Geçme)",
    Default = false,
    Callback = function(Value)
        _G.Noclip = Value
    end
})

SettingsTab:AddSlider({
    Name = "Gravity (Yerçekimi)", Min = 0, Max = 196.2, Default = 196.2,
    Callback = function(v) 
        workspace.Gravity = v 
    end
})

-- ==========================================
-- 🌍 GÖRÜNTÜ VE DÜNYA (VISUALS)
-- ==========================================
SettingsTab:AddSection("Dünya ve Görsellik")

SettingsTab:AddToggle({
    Name = "FullBright (Karanlığı Kaldır)",
    Default = false,
    Callback = function(Value)
        _G.FullBright = Value
        if Value then
            Lighting.Ambient = Color3.new(1, 1, 1)
            Lighting.ColorShift_Bottom = Color3.new(1, 1, 1)
            Lighting.ColorShift_Top = Color3.new(1, 1, 1)
        else
            Lighting.Ambient = Color3.fromRGB(127, 127, 127) -- Varsayılanı geri yükler
        end
    end
})

SettingsTab:AddSlider({
    Name = "FOV (Kamera Görüş Açısı)", Min = 70, Max = 120, Default = 70,
    Callback = function(v) 
        workspace.CurrentCamera.FieldOfView = v
    end
})

-- ==========================================
-- 🛠️ YARDIMCI ARAÇLAR VE TEMİZLİK
-- ==========================================
SettingsTab:AddSection(T("SysClean") or "Sunucu ve Temizlik")

SettingsTab:AddButton({
    Name = "Server Hop (Başka Sunucuya Geç)",
    Callback = function()
        local TeleportService = game:GetService("TeleportService")
        TeleportService:Teleport(game.PlaceId, LP)
    end
})

SettingsTab:AddButton({
    Name = "Rejoin (Aynı Sunucuya Tekrar Gir)",
    Callback = function()
        local TeleportService = game:GetService("TeleportService")
        TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LP)
    end
})

SettingsTab:AddButton({
    Name = T("DestroyHub") or "Arayüzü Sil (Unload)",
    Callback = function()
        _G.LoopSpeed = false
        _G.Noclip = false
        _G.InfJump = false
        MyJanitor:Cleanup()
        sendNotify("Sistem", T("JanitorMsg") or "Titan Omni kapatıldı ve temizlendi.")
    end
})

-- ==========================================
-- 🔄 ARKA PLAN DÖNGÜLERİ VE FONKSİYONLAR
-- ==========================================

-- 1. Premium Scanner Döngüsü
task.spawn(function()
    while task.wait(10) do
        if not HasPremium then
            HasPremium = runEliteScanner()
            if splib then splib.IsPremium = HasPremium end
            if HasPremium then
                sendNotify("Titan Omni", "VIP/Premium Özellikler Aktif Edildi!", "rbxassetid://135403840994127")
            end
        end
    end
end)

-- 2. Noclip, LoopSpeed ve FullBright Döngüsü (Stepped Kullanılır ki sarsıntı yapmasın)
RunService.Stepped:Connect(function()
    pcall(function()
        if not LP.Character then return end
        
        -- Noclip
        if _G.Noclip then
            for _, part in ipairs(LP.Character:GetDescendants()) do
                if part:IsA("BasePart") and part.CanCollide == true then
                    part.CanCollide = false
                end
            end
        end
        
        -- Loop WalkSpeed (Oyun hızı düşürürse zorla geri çek)
        if _G.LoopSpeed and LP.Character:FindFirstChild("Humanoid") then
            LP.Character.Humanoid.WalkSpeed = _G.TargetSpeed
        end
        
        -- FullBright Sürekli Yenileme (Oyun gece yapmaya çalışırsa engeller)
        if _G.FullBright then
            Lighting.ClockTime = 12
            Lighting.GlobalShadows = false
        end
    end)
end)

-- 3. Infinite Jump İşleyicisi
UserInputService.JumpRequest:Connect(function()
    if _G.InfJump and LP.Character and LP.Character:FindFirstChild("Humanoid") then
        LP.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end)

task.spawn(function()
    while task.wait(10) do
        if not HasPremium then
            HasPremium = runEliteScanner()
            if splib then splib.IsPremium = HasPremium end
        end
    end
end)

sendNotify("TITAN V15", T("Loaded") .. " " .. (HasPremium and T("EliteOn") or T("StdOn")), "rbxassetid://135403840994127")w

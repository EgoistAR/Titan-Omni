-- ==========================================
-- 🚀 VOLDEX TURBO: DIRECT REMOTE INJECTION 🚀
-- ==========================================

local function fixTurboManually()
    -- Konsoldaki hatadan "ReplicatedStorage.Packages._Index.voldex_remotes" yolunu görüyoruz.
    -- O yolu kullanarak remote'u bulmaya çalışacağız.
    local remoteFolder = game:GetService("ReplicatedStorage"):FindFirstChild("Packages", true)
                         and game:GetService("ReplicatedStorage"):FindFirstChild("Packages", true):FindFirstChild("_Index", true)
                         and game:GetService("ReplicatedStorage"):FindFirstChild("Packages", true):FindFirstChild("_Index", true):FindFirstChild("voldex_remotes", true)
                         and game:GetService("ReplicatedStorage"):FindFirstChild("Packages", true):FindFirstChild("_Index", true):FindFirstChild("voldex_remotes", true):FindFirstChild("remotes", true)

    if remoteFolder then
        -- Remote'u bulduk! Şimdi Turbo'yu 3. seviyeye set eden fonksiyonu taklit edelim.
        -- Genelde 'SetTurboAppearance' veya benzeri isimdedir.
        local turboRemote = remoteFolder:FindFirstChild("SetTurboAppearance") or remoteFolder:FindFirstChild("SetTurbo")
        
        if turboRemote then
            print("✅ [PATCH] Turbo Remote bulundu: " .. turboRemote.Name)
            
            -- Artık o menüye basmana gerek yok, buradaki butona basınca doğrudan "3" (Max Turbo) gönderir:
            XenoTab:AddButton({
                Name = "🏎️ Force Set Max Turbo (Fix)",
                Callback = function()
                    -- Boolean yerine 3 (Sayı) gönderiyoruz, oyunun hata vermemesi için
                    turboRemote:InvokeServer(3) 
                    sendNotify("🚀 Turbo", "Max Turbo sunucuya gönderildi!")
                end
            })
        end
    else
        warn("⚠️ [PATCH] Remote klasörü bulunamadı. F9'daki yolları kontrol et.")
    end
end

fixTurboManually()

--[[ 
    ADVANCED PLAYER8HANDLER AUTOMATION & BYPASS FRAMEWORK
    Context: FireServer Hijacking & Trigger Automation
]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Player = Players.LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")

-- Hedef Handler
local Handler = PlayerGui:WaitForChild("Player8Handler"):WaitForChild("Game8Settings")

-- 1. METATABLE BYPASS (FireServer Korumalarını Atlatmak İçin)
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod()

    -- Bypass Listesi: Sunucuya giden "zararlı" veya "kısıtlayıcı" paketleri engelle
    local blockedRemotes = {"AntiCheatEvent", "ReportCheat", "SecurityPing","AntiCheat", "AllPassesFetched"}
    
    if method == "FireServer" then
        if table.find(blockedRemotes, self.Name) then
            warn("[BYPASS] Engellenen Event: " .. self.Name)
            return nil -- Sunucuya hiçbir şey gitmesini engelle
        end

        -- Parametre Modifikasyonu (Spam veya Value Bypass)
        if self.Name == "GameAction" then
            args[1] = "Success" -- Sunucuya sürekli 'başarılı' yanıtı gönder
            return oldNamecall(self, unpack(args))
        end
    end

    return oldNamecall(self, ...)
end)
setreadonly(mt, true)

-- 2. OTOMASYON VE TETİKLEYİCİ (TRIGGER) SİSTEMİ
local Automation = {
    AutoRespawn = true,
    AutoTrigger = true
}

local function handleTriggerLogic()
    -- Oyunun içindeki "Trigger" parçalarını veya UI elementlerini izle
    -- Eğer bir "Death" veya "Fail" durumu oluşursa anında müdahale et
    local statusLabel = Handler:FindFirstChild("StatusLabel") -- Örnek UI
    
    if statusLabel and statusLabel.Text == "Eliminated" then
        print("[AUTOMATION] Yeniden doğma tetikleniyor...")
        -- Spawn tetikleyiciyi çağır
        local spawnRemote = ReplicatedStorage:FindFirstChild("SpawnEvent")
        if spawnRemote then spawnRemote:FireServer() end
    end
end

-- 3. DİNAMİK İZLEYİCİ (Handler Monitor)
Handler.Changed:Connect(function()
    if Automation.AutoTrigger then
        handleTriggerLogic()
    end
end)

-- 4. ANTİ-AFK (Oyunun seni dışarı atmasını engelle)

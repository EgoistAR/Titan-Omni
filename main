local RBXSystem = TextChatService:WaitForChild("TextChannels"):WaitForChild("RBXSystem")
local partyTypes = { ["House Party"] = "HouseParty", ["Birthday Party"] = "BirthdayParty", ["Dance Party"] = "DanceParty", ["Taco Party"] = "TacoParty" }

local function sendRealisticMessage(partyName)
    local lotNum = LotUtil.GetPlayerOwnedLotNumber(LP) or "?"
    local message = string.format(
        "<font color='#eba0e0'>[Server]: </font><font weight='SemiBold' color='#fac519'>%s</font> started a <font weight='SemiBold'>%s</font> at house <font weight='SemiBold'>#%s</font>!",
        LP.DisplayName, partyName, tostring(lotNum)
    )
    RBXSystem:DisplaySystemMessage(message)
end

local function inviteEveryone(partyId)
    local allPlayerIds = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LP then table.insert(allPlayerIds, player.UserId) end
    end
    Remotes.fireServer("StartFreeParty", partyId, allPlayerIds)
end


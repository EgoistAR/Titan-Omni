local splib = loadstring(game:HttpGet("https://raw.githubusercontent.com/as6cd0/SP_Hub/refs/heads/main/splibv2"))()

local Janitor = (function()
    local t2 = { ClassName = "Janitor", CurrentlyCleaning = false }
    t2.__index = t2
    local v2 = setmetatable({}, { __mode = "ks" })
    local t3 = { ["function"] = true, thread = true, RBXScriptConnection = "Disconnect" }
    function t2.new() return setmetatable({}, t2) end
    function t2.Add(p1, p2, p3, p4)
        local v1 = v2[p1] or {}
        v2[p1] = v1
        p1[p2] = p3 or t3[typeof(p2)] or "Destroy"
        return p2
    end
    function t2.Cleanup(p1)
        if p1.CurrentlyCleaning then return end
        p1.CurrentlyCleaning = true
        for obj, method in pairs(p1) do
            if type(method) == "string" and obj[method] then pcall(function() obj[method](obj) end)
            elseif method == true then pcall(function() if type(obj) == "function" then obj() else task.cancel(obj) end end) end
        end
        p1.CurrentlyCleaning = false
    end
    return t2
end)()
local MyJanitor = Janitor.new()

local RE = RS:WaitForChild("RE", 15)
local RemotesFolder = RS:WaitForChild("Remotes", 9e9)
local PREMIUM_ID = 1829479246
local TARGET_PLACE_ID = 109590042344227
local HasPremium = false
local RemoteCache = {}

local function sendNotify(title, msg, icon, duration)
    if splib and splib.MakeNotification then
        splib:MakeNotification({ Name = tostring(title), Content = tostring(msg), Time = duration or 4, Icon = icon or "rbxassetid://135403840994127" })
    end
end

local function FindRemote(remoteName)
    if RemoteCache[remoteName] then return RemoteCache[remoteName] end
    local remote = RE:FindFirstChild(remoteName) or RemotesFolder:FindFirstChild(remoteName) or RS:FindFirstChild(remoteName)
    if remote then RemoteCache[remoteName] = remote end
    return remote
end

local function RequestItemMax(itemName)
    if not itemName then return false end
    local candidates = {"GetItem", "Getİtem", "Get_Item", "GetTool", "1Too1l", "GiveItem"}
    local triggerNames = {"1Playe1rTrigge1rEven1t", "PlayerTrigger", "AcceptedToolToServer"}
    for _, name in ipairs(candidates) do
        local remote = FindRemote(name)
        if remote then
            pcall(function()
                if remote:IsA("RemoteFunction") then remote:InvokeServer(itemName)
                elseif remote:IsA("RemoteEvent") then remote:FireServer(itemName) end
            end)
        end
    end
    for _, triggerName in ipairs(triggerNames) do
        local triggerRemote = FindRemote(triggerName)
        if triggerRemote and triggerRemote:IsA("RemoteEvent") then
            pcall(function() triggerRemote:FireServer("AcceptedToolToServer", itemName, LP) end)
        end
    end
    return true
end


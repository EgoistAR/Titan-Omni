local AITab = Window:MakeTab({ Title = "🧠 AI Scanner", Icon = "rbxassetid://15309138473" }) -- İkonu değiştirebilirsin

-- Değişkenler
local ExecutorName, ExecutorVersion = "Bilinmiyor", "Bilinmiyor"
local ScriptErrors = 0

-- 1. EXECUTOR (HİLE PROGRAMI) ANALİZİ
local function checkExecutor()
    local success, exec, ver = pcall(function()
        return identifyexecutor()
    end)
    
    if success and exec then
        ExecutorName = exec
        ExecutorVersion = tostring(ver)
    else
        ExecutorName = "Tespit Edilemedi"
    end
end
checkExecutor()

AITab:AddParagraph({
    Title = "🕵️ Executor (Hile) Analizi",
    Content = "Kullandığın Program: " .. ExecutorName .. "\nVersiyon: " .. ExecutorVersion .. "\nDurum: Tarandı ve aktif olarak çalışıyor."
})

AITab:AddButton({
    Name = "🔄 Update / Status Check",
    Callback = function()
        if ExecutorName == "Tespit Edilemedi" then
            sendNotify("⚠️ AI Uyarısı", "Bilinmeyen bir executor kullanıyorsun, çökmelere yol açabilir.")
        else
            sendNotify("✅ AI Raporu", ExecutorName .. " şu an aktif. Güncellemeler için sağlayıcının Discord'unu kontrol et.")
        end
    end
})

-- 2. SCRIPT (SP HUB) HATA TARAYICISI
AITab:AddParagraph({
    Title = "🛡️ Script Error Monitor (Canlı Tarama)",
    Content = "Şu an arka planda SP Hub ve diğer scriptlerin hataları izleniyor..."
})

-- Oyun içi oluşan hataları (kırmızı konsol yazıları) otomatik yakala
game:GetService("ScriptContext").Error:Connect(function(message, trace, script)
    -- Sadece senin executor'ından veya belirlediğin hub'dan gelen hataları filtrele
    -- Eğer trace veya script ismi tanıdıksa yakala
    ScriptErrors = ScriptErrors + 1
    print("🧠 [AI ERROR SCANNER] Bir Hata Yakalandı!")
    print("Hata Mesajı: " .. message)
    
    -- Kullanıcıya UI üzerinden sadece önemli olduğunda bildirim gönder
    if ScriptErrors <= 3 then -- Çok fazla spam yapmaması için limit
        sendNotify("🔴 AI Script Hatası Yakaladı", "Sorun: " .. string.sub(message, 1, 40) .. "...\nDetaylar için F9'a (Konsol) bak.")
    end
end)

AITab:AddButton({
    Name = "📋 Hata Raporunu Yazdır (F9)",
    Callback = function()
        sendNotify("🧠 AI Raporu", "Toplam yakalanan anlık hata sayısı: " .. tostring(ScriptErrors))
        print("--- AI DETAYLI RAPOR ---")
        print("Executor: " .. ExecutorName)
        print("Toplam Hata: " .. tostring(ScriptErrors))
        if ScriptErrors == 0 then
            print("Durum: MÜKEMMEL. SP Hub / Script tamamen stabil çalışıyor.")
        else
            print("Durum: DİKKAT. Script bazı fonksiyonlarda çöküyor olabilir.")
        end
    end
})


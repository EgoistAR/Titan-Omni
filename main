        local success, err = pcall(function()
            return VehicleController.SpawnVehicle(XenoSettings.VehicleID)
        end)

        if success then
            sendNotify("✅ Success", "Spawned: " .. XenoSettings.VehicleID .. " 🏎️")
        else
            sendNotify("❌ Error", "Spawn failed: " .. tostring(err))
        end
    end
})


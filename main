local Player = game:GetService("Players").LocalPlayer
local Mouse = Player:GetMouse()

local ClickToPlaceActive = false
local ClickConnection = nil

-- Tıklayarak Koyma Toggle'ı
XenoTab:AddToggle({
    Name = "🖱️ Mouse Click to Place (Hedefe Fırlat)",
    Default = false,
    Callback = function(Value)
        ClickToPlaceActive = Value
        
        if ClickToPlaceActive then
            sendNotify("🖱️ Click to Place", "Aktif! Haritada tıkladığın her yere prop yağdırabilirsin. 🎯")
            
            -- Farenin sol tık olayını dinlemeye başla
            ClickConnection = Mouse.Button1Down:Connect(function()
                if ClickToPlaceActive then
                    -- Farenin haritada tıkladığı noktanın tam CFrame (pozisyon ve açı) değerini al
                    local targetCFrame = Mouse.Hit
                    
                    -- Önceki sistemde tanımladığımız PropNameOrId değişkenini kullanıyoruz
                    local propRemote = game:GetService("ReplicatedStorage"):FindFirstChild("SpawnProp", true)
                    
                    if propRemote then
                        -- Sunucuya farenin tıkladığı yeri hedef olarak gönder
                        propRemote:FireServer(PropNameOrId, targetCFrame)
                        print("🎯 [PROP] Hedefe başarıyla fırlatıldı: " .. tostring(targetCFrame.Position))
                    else
                        warn("⚠️ [PROP] SpawnProp remote'u bulunamadı! F9 ile doğru ismi kontrol et.")
                    end
                end
            end)
        else
            sendNotify("🛑 Click to Place", "Tıklayarak eşya koyma devre dışı bırakıldı.")
            
            -- Sistemi kapattığında belleği (memory) yormamak için bağlantıyı kes
            if ClickConnection then
                ClickConnection:Disconnect()
                ClickConnection = nil
            end
        end
    end
})


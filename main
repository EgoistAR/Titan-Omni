local Player = game:GetService("Players").LocalPlayer

-- 1. AVATAR MENÜSÜ KİLİT KIRICI
local function unlockAvatarMenu()
    local success, err = pcall(function()
        -- Eğer oyunun özel bir Avatar Controller'ı varsa onu bul ve hackle
        local Modules = game:GetService("ReplicatedStorage"):FindFirstChild("Modules")
        if Modules then
            local avatarController = Modules:FindFirstChild("AvatarController", true) or 
                                     Modules:FindFirstChild("ClothingController", true)
            
            if avatarController then
                local req = require(avatarController)
                if type(req) == "table" then
                    -- Kıyafet limitlerini ve premium kontrollerini kaldır
                    local checks = {"IsPremium", "CanWear", "OwnsAsset", "IsUnlocked"}
                    for _, func in pairs(checks) do
                        if type(req[func]) == "function" then
                            req[func] = function() return true end
                        end
                    end
                    print("👕 [AVATAR] Avatar/Kıyafet menüsü VIP kontrolleri kırıldı!")
                end
            end
        end
    end)
    return success
end

-- 2. CUSTOM ASSET GİYDİRİCİ (Zorla Eşya Taktırma)
local function forceEquipItem(assetId, assetType)
    local character = Player.Character or Player.CharacterAdded:Wait()
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    
    if not humanoid then return end

    pcall(function()
        -- HumanoidDescription kullanarak anında eşyayı giydiriyoruz
        local currentDesc = humanoid:GetAppliedDescription() or Instance.new("HumanoidDescription")
        
        if assetType == "Shirt" then
            currentDesc.Shirt = assetId
        elseif assetType == "Pants" then
            currentDesc.Pants = assetId
        elseif assetType == "Face" then
            currentDesc.Face = assetId
        elseif assetType == "Accessory" then
            local accList = currentDesc.HatAccessory
            currentDesc.HatAccessory = accList == "" and tostring(assetId) or accList .. "," .. tostring(assetId)
        end
        
        humanoid:ApplyDescription(currentDesc)
        print("🎩 [AVATAR] Eşya başarıyla giyildi: " .. tostring(assetId))
    end)
end


XenoTab:AddButton({
    Name = "🕵️ Scan VehicleService (Deep AI)",
    Callback = function()
        print("====================================")
        print("🧠 [AI SCAN] VEHICLESERVICE ANALİZİ BAŞLADI...")
        print("====================================")

        -- 1. Servisi Bulmayı Dene
        local VehicleService = game:GetService("ServerScriptService"):FindFirstChild("VehicleService", true) or 
                               game:GetService("ReplicatedStorage"):FindFirstChild("VehicleService", true) or
                               game:GetService("ServerScriptService"):FindFirstChild("VehicleService")

        if not VehicleService then
            warn("⚠️ [AI] VehicleService doğrudan bulunamadı (Sunucu korumalı olabilir).")
            sendNotify("❌ AI Tarama", "VehicleService doğrudan erişime kapalı! Alternatif aranıyor...")
            return
        end

        print("🎯 Nesne Türü (ClassName): " .. tostring(VehicleService.ClassName))
        print("📍 Konum: " .. VehicleService:GetFullName())

        -- 2. Eğer bir Modül (ModuleScript) ise İçeriğini Metatable ile Oku
        if VehicleService:IsA("ModuleScript") then
            local success, content = pcall(function()
                return require(VehicleService)
            end)

            if success and type(content) == "table" then
                print("\n📂 [MODÜL İÇERİĞİ] Fonksiyonlar ve Değişkenler:")
                for key, value in pairs(content) do
                    print("  ➡️ [" .. type(value) .. "] " .. tostring(key))
                end
            else
                print("⚠️ [AI] Modül içeriği 'require' edilemedi (Sadece server-side çalışıyor olabilir).")
            end
        end

        -- 3. Altındaki Gizli RemoteEvent ve RemoteFunction'ları Avla
        print("\n📡 [REMOTE DETECTOR] Alt Nesneler Taranıyor:")
        local remotesFound = 0
        for _, child in pairs(VehicleService:GetDescendants()) do
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                remotesFound = remotesFound + 1
                print("  📡 Tür: [" .. child.ClassName .. "] | Adı: " .. child.Name .. " | Yol: " .. child:GetFullName())
            end
        end

        if remotesFound == 0 then
            print("  ℹ️ Altında doğrudan RemoteEvent bulunamadı. Ana ağ klasörüne bağlı olabilir.")
        end

        print("====================================")
        print("✅ [AI SCAN] Tarama Tamamlandı! Detaylar için F9 Konsoluna Bak.")
        print("====================================")
        sendNotify("🔍 Scanner", "VehicleService başarıyla tarandı! F9'a bak. ✨")
    end
})

-- ==========================================
-- 🧱 UNLIMITED PROP & SPAM ENGINE (BİNLERCE EŞYA) 🧱
-- ==========================================

local UserInputService = game:GetService("UserInputService")
local Mouse = game:GetService("Players").LocalPlayer:GetMouse()

local PropSpamActive = false
local PropNameOrId = "CardboardBox" -- Oyunun prop ismine göre değişebilir

-- 1. PROP LİMİTLERİNİ VE BEKLEME SÜRESİNİ (COOLDOWN) KIRMA 🔨
local function bypassPropLimits()
    local success, err = pcall(function()
        local Modules = game:GetService("ReplicatedStorage"):FindFirstChild("Modules")
        if not Modules then return end

        -- Prop veya Mobilya Controller'ını bul
        local propMod = Modules:FindFirstChild("PropController", true) or 
                        Modules:FindFirstChild("PlacementController", true) or
                        Modules:FindFirstChild("FurnitureController", true)
                        
        if propMod then
            local PropController = require(propMod)
            if type(PropController) == "table" then
                
                -- Limit fonksiyonlarını hackle
                local limitFuncs = {"AtLimit", "CanPlace", "HasCooldown"}
                for _, f in pairs(limitFuncs) do
                    if type(PropController[f]) == "function" then
                        if f == "CanPlace" then
                            PropController[f] = function() return true end -- Her zaman yerleştirilebilir
                        else
                            PropController[f] = function() return false end -- Limit yok, cooldown yok
                        end
                    end
                end
                
                -- Maksimum Prop sayısını sonsuz yap
                if PropController.GetMaxProps then
                    PropController.GetMaxProps = function() return 999999 end
                end
                if PropController.MaxProps then 
                    PropController.MaxProps = 999999 
                end
                if PropController.Cooldown then 
                    PropController.Cooldown = 0 
                end

                print("🧱 [PROP] Limitler yok edildi! Sınırsız eşya yerleştirilebilir.")
            end
        end
    end)
    return success
end

-- 2. XENOTAB UI: PROP KONTROLLERİ 🎛️
XenoTab:AddButton({
    Name = "🔓 Bypass Prop Limits (Limitleri Kaldır)",
    Callback = function()
        bypassPropLimits()
        sendNotify("🧱 Prop Bypass", "Limitler kaldırıldı! Sınırsız prop koyabilirsin. 🌪️")
    end
})


local function ExecuteRemote(remoteName, ...)
    local remote = FindRemote(remoteName)
    if not remote then return false end
    local args = {...}
    return pcall(function()
        if remote:IsA("RemoteEvent") then remote:FireServer(unpack(args))
        elseif remote:IsA("RemoteFunction") then task.spawn(function() remote:InvokeServer(unpack(args)) end) end
    end)
end


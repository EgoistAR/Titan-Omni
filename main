-- Bypass Fonksiyonu
local function spawnBypassVehicle(carName)
    pcall(function()
        -- 1. ADIM: "Ghost Profiling" - Sunucuya "Benim garajımda bu araç var" imajı ver
        ProfilingRemote:FireServer({
            identifier = "MainVehicleMenu",
            selectedVehicle = carName,
            isPremium = true, -- Sunucuya her zaman premium olduğumuzu söylüyoruz
            isOwner = true    -- Araca sahip olduğumuzu belirtiyoruz
        })

        -- 2. ADIM: "Force Fire" - Bypasslı şekilde ateşle
        task.spawn(function()
            -- Sunucuya aracı zorla spawn ettir
            SpawnRemote:FireServer("PickingCar", carName)
            
            -- Eğer araç gelmediyse, sunucu "hata" verdiyse tekrar gönder
            task.wait(0.5)
            SpawnRemote:FireServer("Equip", carName)
        end)
        
        sendNotify("🚀 Vehicle Engine", "Bypass aktif: " .. carName .. " gönderildi!")
    end)
end


        end)
    end
})

local function ApplyGodMode()
    pcall(function()
        require(RS.Modules.Shared.Permissions).hasAdminAccess = function() return true end
        require(RS.Modules.Shared.Cmdr.CmdrPermissions).hasCmdrAccess = function() return true end
        require(RS.Modules.Shared.Utils.GroupUtil).isAdmin = function() return true end
        require(RS.Modules.Shared.Utils.GroupUtil).getRank = function() return 255 end
        require(RS.Modules.Shared.Game.GameUtil).IsPrivateServerOwner = function() return true end
    end)
end

local v2 = false
local function setupCmdr()
    if v2 then return end
    v2 = true
    ApplyGodMode()
    task.delay(1, function()
        local CmdrClient = RS:WaitForChild("CmdrClient")
        local v3 = require(CmdrClient)
        v3:SetActivationKeys({ Enum.KeyCode.F2, Enum.KeyCode.Semicolon })
        v3:Toggle()
    end)
end

local function ShowString(p1)
    local LogString = Instance.new("ScreenGui", LP.PlayerGui)
    local LogString_2 = Instance.new("TextBox", LogString)
    LogString_2.AnchorPoint = Vector2.new(0.5, 0.5)
    LogString_2.Position = UDim2.new(0.5, 0, 0.5, 0)
    LogString_2.Size = UDim2.new(0.3, 0, 0.3, 0)
    LogString_2.Text = p1
    local CloseBtn = Instance.new("TextButton", LogString_2)
    CloseBtn.Size = UDim2.new(1, 0, 0, 30)
    CloseBtn.Position = UDim2.new(0, 0, 1, 0)
    CloseBtn.Text = "Kapat"
    CloseBtn.MouseButton1Click:Connect(function() LogString:Destroy() end)
end


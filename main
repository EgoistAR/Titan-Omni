-- ==========================================
-- 🌟 PLUS / PREMIUM HIJACKER (TAM ELE GEÇİRME) 🌟
-- ==========================================

local function hijackPlusSystem()
    local success, err = pcall(function()
        local Player = game:GetService("Players").LocalPlayer

        -- 1. GAMEPASS CONTROLLER'I EZ (ZORLA PLUS YAP)
        if type(GamepassController) == "table" then
            local plusFunctions = {"HasPass", "OwnsGamepass", "IsPremium", "IsPlus", "HasPlus","ShowGamepass","IM_GamepassAll","PromptColorGamepassNeeded","PromptGamepassPurchase"}
            
            -- Oyun "Plus var mı?" diye soran hangi fonksiyonu kullanırsa kullansın, 'Evet' dedirtiyoruz
            for _, funcName in pairs(plusFunctions) do
                if type(GamepassController[funcName]) == "function" then
                    GamepassController[funcName] = function() 
                        return true 
                    end
                end
            end
            
            -- Eğer oyun Gamepass'leri bir liste içinde tutuyorsa o listeyi hackle
            if type(GamepassController.OwnedPasses) == "table" then
                setmetatable(GamepassController.OwnedPasses, {
                    __index = function() return true end
                })
            end
        end

        -- 2. LOCALPLAYER ATTRIBUTE & VALUE MANİPÜLASYONU
        -- Bazı oyunlar Plus kontrolünü oyuncunun içine gizler, onları da true yapıyoruz
        Player:SetAttribute("Premium", true)
        Player:SetAttribute("Plus", true)
        Player:SetAttribute("VIP", true)
        Player:SetAttribute("IsPlus", true)

        -- Veri klasörü kontrolü (Data/leaderstats)
        local playerData = Player:FindFirstChild("Data") or Player:FindFirstChild("leaderstats")
        if playerData then
            for _, v in pairs(playerData:GetChildren()) do
                local name = string.lower(v.Name)
                if string.find(name, "plus") or string.find(name, "premium") or string.find(name, "vip") then
                    if v:IsA("BoolValue") then 
                        v.Value = true 
                    end
                end
            end
        end
    end)
    return success, err
end


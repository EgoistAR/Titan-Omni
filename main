local function safeHook(funcName)
    local success, result = pcall(function()
        return funcName()
    end)
    return success
end

-- // Voldex SDK & Component Core Interceptor (Executor Özel Sürümü)
local ReplicatedStorage = game:GetService("ReplicatedStorage")

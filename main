XenoTab:AddToggle({
    Name = "🌪️ AUTO-SPAM PROPS (Binlerce Koy)",
    Default = false,
    Callback = function(Value)
        PropSpamActive = Value
        if PropSpamActive then
            sendNotify("🌪️ Spam Active", "Etrafına saniyede onlarca prop yağıyor! Çöktürmemeye dikkat et. 💥")
            task.spawn(function()
                while PropSpamActive do
                    task.wait(0.05) -- Saniyede 20 prop atar (Sınırları zorlar)
                    local char = game:GetService("Players").LocalPlayer.Character
                    if char and char:FindFirstChild("HumanoidRootPart") then
                        -- Karakterin etrafında rastgele yerlere fırlat
                        local randomOffset = Vector3.new(math.random(-15,15), 5, math.random(-15,15))
                        local pos = char.HumanoidRootPart.CFrame * CFrame.new(randomOffset)
                        
                        local propRemote = game:GetService("ReplicatedStorage"):FindFirstChild("SpawnProp", true)
                        if propRemote then
                            propRemote:FireServer(PropNameOrId, pos)
                        end
                    end
                end
            end)
        else
            sendNotify("🛑 Spam Stopped", "Prop yağmuru durduruldu.")
        end
    end
})


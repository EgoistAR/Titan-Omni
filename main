-- ==========================================
-- [AI] TITAN TEXT-FIXER (GENERIC TEXT NORMALIZER)
-- ==========================================
local TITAN_AI = {
    FilterActive = true,
    CorrectionMap = {
        ["oe"] = "ö", ["OE"] = "Ö", ["ae"] = "ä", ["AE"] = "Ä",
        ["ue"] = "ü", ["UE"] = "Ü", ["ss"] = "ß", ["SS"] = "ß",
        ["sh"] = "ş", ["SH"] = "Ş", ["ch"] = "ç", ["CH"] = "Ç",
        ["gh"] = "ğ", ["GH"] = "Ğ", ["ie"] = "ı", ["IE"] = "İ",
        ["[VNG_BLOCK]"] = "", ["[BLOCK]"] = "",
        ["\\n"] = "\n", ["\\t"] = "\t", ["  "] = " ",
    },
    StripMap = {
        ["  "] = " ", ["   "] = " ", ["    "] = " ", ["\r"] = "",
    }
}

function TITAN_AI:FixCorrupted(text)
    if type(text) ~= "string" then return text end
    local out = text
    for from, to in pairs(self.CorrectionMap) do out = out:gsub(from, to) end
    out = out:gsub("%s+([,%.%!%?%:;])", "%1")
    out = out:gsub("([,%.%!%?%:;])([A-Za-zÇĞİÖŞÜçğıöşü])", "%1 %2")
    out = out:gsub("%s+", " ")
    out = out:gsub("^%s+", ""):gsub("%s+$", "")
    return out
end

function TITAN_AI:CleanForVNG(text)
    if type(text) ~= "string" then return text end
    local out = text
    out = out:gsub("ö", "o"):gsub("Ö", "O"):gsub("ü", "u"):gsub("Ü", "U")
    out = out:gsub("ä", "a"):gsub("Ä", "A"):gsub("ş", "s"):gsub("Ş", "S")
    out = out:gsub("ç", "c"):gsub("Ç", "C"):gsub("ğ", "g"):gsub("Ğ", "G")
    out = out:gsub("ı", "i"):gsub("İ", "I")
    out = out:gsub("%[VNG_BLOCK%]", ""):gsub("%[BLOCK%]", "")
    out = out:gsub("%s+", " "):gsub("^%s+", ""):gsub("%s+$", "")
    return out
end

function TITAN_AI:FixText(text, safeMode)
    if not self.FilterActive then return text end
    local out = self:FixCorrupted(text)
    if safeMode then out = self:CleanForVNG(out) end
    return out
end


local VehicleCatalog = {}

-- 1. AI Katalog Tarayıcı 🧠
local function scanVehicles()
    local catalogFolder = ReplicatedStorage:FindFirstChild("Vehicles", true) or 
                          ReplicatedStorage:FindFirstChild("Catalog", true)
    
    if catalogFolder then
        for _, obj in pairs(catalogFolder:GetChildren()) do
            VehicleCatalog[obj.Name] = obj.Name 
        end
    end
end
scanVehicles()


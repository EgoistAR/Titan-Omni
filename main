-- Global bir tablo oluşturuyoruz ki 'return' kullanmak zorunda kalmayalım
if _G.GameSdkMaster then
    _G.GameSdkMaster = nil -- Eski çalışan kanca varsa temizle
end

_G.GameSdkMaster = {
    LogTelemetry = true,
    LogPathing = false,
    FakeDataMode = true
}

-- Orijinal metatable metodunu yedekle
local targetVirtualInstance = Instance.new("RemoteEvent")
local originalFireServer = targetVirtualInstance.FireServer
local originalNamecall

-- // 1. BÖLÜM: Ağ Trafiği Filtresi (Network Interceptor)
local rawMetatable = getrawmetatable(game)
setreadonly(rawMetatable, false)

originalNamecall = rawMetatable.__namecall
rawMetatable.__namecall = newcclosure(function(self, ...)
    local callingMethod = getnamecallmethod()
    local executionArgs = {...}
    
    if callingMethod == "FireServer" and typeof(self) == "Instance" and self:IsA("RemoteEvent") then
        local eventName = self.Name
        
        -- Telemetri (İzleme Verileri) Filtresi
        if string.find(eventName, "GameSdkTelemetry") then
            if _G.GameSdkMaster.LogTelemetry then
                warn("[GameSdk-Interceptor] Telemetri paketi yakalandı: " .. eventName)
            end
            if _G.GameSdkMaster.FakeDataMode then
                executionArgs[1] = {} 
                return originalFireServer(self, unpack(executionArgs))
            end
            return
        end
        
        -- Pathing (Konum ve Kamera Takibi) Filtresi
        if string.find(eventName, "GameSdkPathing") then
            if _G.GameSdkMaster.LogPathing then
                print("[GameSdk-Interceptor] Pathing verisi engellendi: " .. eventName)
            end
            if _G.GameSdkMaster.FakeDataMode then
                executionArgs[1] = {
                    characterPosition = {Vector3.new(0, 10, 0)},
                    cameraCFrame = {CFrame.new(0, 10, 0)}
                }
                return originalFireServer(self, unpack(executionArgs))
            end
            return
        end
    end
    
    return originalNamecall(self, ...)
end)

setreadonly(rawMetatable, true)

-- // 2. BÖLÜM: Bileşen Yönetimi Fonksiyonları
_G.GameSdkMaster.GetActiveComponents = function(tagName)
    local taggedInstances = CollectionService:GetTagged(tagName)
    local foundComponents = {}
    
    local success, ComponentUtil = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Shared"):WaitForChild("Utils"):WaitForChild("ComponentUtil"))
    end)
    
    if success and ComponentUtil then
        for _, instance in ipairs(taggedInstances) do
            local comp = ComponentUtil.FindComponentByAncestor(instance, tagName)
            if comp then
                table.insert(foundComponents, comp)
            end
        end
    end
    return foundComponents
end

_G.GameSdkMaster.ForceToggleUI = function()
    for _, screenGui in ipairs(game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui"):GetChildren()) do
        local settingsFrame = screenGui:FindFirstChild("Settings", true) or screenGui:FindFirstChild("SettingFrame", true)
        if settingsFrame then
            for _, child in ipairs(settingsFrame:GetChildren()) do
                if child:IsA("Frame") then
                    child.Visible = not child.Visible
                end
            end
        end
    end
end


-- 3. HEDEF LİSTESİNDEKİ TÜM UI VE MODÜLLERİ ZORLA AÇMA DÖNGÜSÜ
-- =============================================================================
local function ForceUnlockTarget(instance)
    if not instance then return end
    
    -- Eğer obje bizim listemizdeki bir şeyse:
    if table.find(TargetModules, instance.Name) then
        -- 1. Arayüz elemanıysa görünür ve tıklanabilir yap
        if instance:IsA("GuiObject") then
            instance.Visible = true
            instance.Active = true
            -- Eğer buton ise tıklama kilitlerini aç
            if instance:IsA("ImageButton") or instance:IsA("TextButton") then
                instance.AutoButtonColor = true
                instance.Selectable = true
            end
        end
        
        -- 2. Attribute limitlerini sıfırla (Max hız, Premium renk kilidi vb.)
        if instance:GetAttribute("SingleVehicleSpawn") then
            instance:SetAttribute("SingleVehicleSpawn", "")
        end
        if instance:GetAttribute("SpawnColor") then
            instance:SetAttribute("SpawnColor", "Really black")
        end
        if instance:GetAttribute("IsPremium") or instance:GetAttribute("IsVIP") then
            instance:SetAttribute("IsPremium", false)
            instance:SetAttribute("IsVIP", false)
        end
    end
end

